# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Database ─────────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when a Postgres service is linked
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ─── Server ───────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override in production
PORT=3000

# Auction settlement cron — used by /api/auctions/close
# Generate with: openssl rand -hex 24
CRON_SECRET=

# ─── Country / Region ─────────────────────────────────────────────────────────
# Used to filter listings/users/orders by country in the shared multi-tenant DB
NEXT_PUBLIC_COUNTRY_CODE=US
